{
  "version": "1.0",
  "framework": "primeng",
  "angularVersion": "17.3",

  "imports": {
    "description": "Standard PrimeNG imports for a CRUD component",
    "component": [
      "ButtonModule",
      "InputTextModule",
      "TableModule",
      "CardModule",
      "DialogModule",
      "ToastModule",
      "ConfirmDialogModule",
      "DropdownModule",
      "CalendarModule",
      "InputTextareaModule",
      "CommonModule",
      "FormsModule",
      "ReactiveFormsModule"
    ],
    "nav": [
      "MenubarModule",
      "CommonModule",
      "RouterLink",
      "RouterLinkActive"
    ],
    "home": [
      "CardModule",
      "ButtonModule",
      "CommonModule",
      "RouterLink"
    ]
  },

  "button": {
    "primary": "<p-button label=\"Label\" severity=\"primary\"></p-button>",
    "secondary": "<p-button label=\"Label\" severity=\"secondary\"></p-button>",
    "danger": "<p-button icon=\"pi pi-trash\" severity=\"danger\" [rounded]=\"true\" [text]=\"true\"></p-button>",
    "icon": "<p-button icon=\"pi pi-pencil\" severity=\"info\" [rounded]=\"true\" [text]=\"true\"></p-button>"
  },

  "input": {
    "text": "<div class=\"field mb-4\">\n  <label class=\"block font-medium mb-1\">Label</label>\n  <input pInputText type=\"text\" class=\"w-full\" [(ngModel)]=\"model.field\" name=\"field\" required>\n</div>",
    "select": "<div class=\"field mb-4\">\n  <label class=\"block font-medium mb-1\">Label</label>\n  <p-dropdown [options]=\"options\" [(ngModel)]=\"model.field\" name=\"field\" optionLabel=\"label\" optionValue=\"value\" class=\"w-full\"></p-dropdown>\n</div>",
    "date": "<div class=\"field mb-4\">\n  <label class=\"block font-medium mb-1\">Date</label>\n  <input pInputText type=\"date\" class=\"w-full\" [(ngModel)]=\"model.dateField\" name=\"dateField\">\n</div>",
    "textarea": "<div class=\"field mb-4\">\n  <label class=\"block font-medium mb-1\">Label</label>\n  <textarea pInputTextarea class=\"w-full\" [(ngModel)]=\"model.field\" name=\"field\" rows=\"3\"></textarea>\n</div>"
  },

  "table": {
    "description": "PrimeNG p-table with paginator, filter, sort",
    "html": "<p-table [value]=\"items\" [paginator]=\"true\" [rows]=\"10\" [rowsPerPageOptions]=\"[10, 25, 50]\" [sortMode]=\"'multiple'\" styleClass=\"p-datatable-striped\">\n  <ng-template pTemplate=\"header\">\n    <tr>\n      <th pSortableColumn=\"col1\">Column 1 <p-sortIcon field=\"col1\"></p-sortIcon></th>\n      <th>Actions</th>\n    </tr>\n  </ng-template>\n  <ng-template pTemplate=\"body\" let-item>\n    <tr>\n      <td>{{ item.col1 }}</td>\n      <td>\n        <p-button icon=\"pi pi-pencil\" severity=\"info\" [rounded]=\"true\" [text]=\"true\" (click)=\"selectForEdit(item)\"></p-button>\n        <p-button icon=\"pi pi-trash\" severity=\"danger\" [rounded]=\"true\" [text]=\"true\" (click)=\"delete(item.id!)\"></p-button>\n      </td>\n    </tr>\n  </ng-template>\n  <ng-template pTemplate=\"emptymessage\">\n    <tr><td colspan=\"2\">No data found.</td></tr>\n  </ng-template>\n</p-table>"
  },

  "card": {
    "basic": "<p-card header=\"Title\" subheader=\"Subtitle\">\n  <p>Content</p>\n  <ng-template pTemplate=\"footer\">\n    <p-button label=\"Action\" severity=\"primary\"></p-button>\n  </ng-template>\n</p-card>",
    "form": "<p-card [header]=\"(selectedItem?.id ? 'Edit' : 'New') + ' Entity'\">\n  <form #form=\"ngForm\" (ngSubmit)=\"save()\">\n    <!-- field inputs here -->\n    <div class=\"flex gap-2 mt-4\">\n      <p-button type=\"submit\" label=\"Save\" severity=\"primary\" [disabled]=\"form.invalid\"></p-button>\n      <p-button type=\"button\" label=\"Cancel\" severity=\"secondary\" (click)=\"reset()\"></p-button>\n    </div>\n  </form>\n</p-card>"
  },

  "navbar": {
    "description": "PrimeNG menubar navigation",
    "html": "<p-menubar [model]=\"menuItems\">\n  <ng-template pTemplate=\"start\">\n    <a routerLink=\"/home\" class=\"text-xl font-bold no-underline text-white\">App</a>\n  </ng-template>\n</p-menubar>"
  },

  "listView": {
    "description": "Two-column PrimeNG layout: p-table left, p-card form right",
    "html": "<div class=\"p-4\">\n  <div class=\"flex align-items-center justify-content-between mb-4\">\n    <h2 class=\"text-3xl font-bold\">ENTITY_PLURAL</h2>\n    <p-button label=\"+ New ENTITY\" severity=\"primary\" *ngIf=\"!selectedItem\" (click)=\"startCreate()\"></p-button>\n  </div>\n  <div class=\"flex gap-4 align-items-start\">\n    <div class=\"flex-1\"><!-- p-table here --></div>\n    <div style=\"width: 35%\" *ngIf=\"selectedItem\"><!-- p-card form here --></div>\n  </div>\n</div>"
  },

  "promptHints": {
    "description": "Rules the AI MUST follow when generating PrimeNG Angular components",
    "rules": [
      "ALWAYS use PrimeNG components. NEVER use Bootstrap, Angular Material, or bare unstyled HTML elements.",
      "Tables: use <p-table [value]=\"items\"> with <ng-template pTemplate=\"header\">, <ng-template pTemplate=\"body\" let-item>, <ng-template pTemplate=\"emptymessage\">.",
      "Add [paginator]=\"true\" [rows]=\"10\" [rowsPerPageOptions]=\"[10,25,50]\" to p-table.",
      "Buttons: <p-button label=\"...\" severity=\"primary|secondary|danger|info\"> — NEVER use <button class=\"btn ...\">.",
      "Icon buttons in table: <p-button icon=\"pi pi-pencil\" severity=\"info\" [rounded]=\"true\" [text]=\"true\"> and <p-button icon=\"pi pi-trash\" severity=\"danger\" [rounded]=\"true\" [text]=\"true\">.",
      "Form inputs: <input pInputText type=\"text\" class=\"w-full\" [(ngModel)]=\"selectedItem.field\" name=\"field\">",
      "Labels: <label class=\"block font-medium mb-1\">",
      "Form group: <div class=\"field mb-4\">",
      "Card wrapper for forms: <p-card [header]=\"...\">",
      "Use browser confirm() for delete confirmation.",
      "All components must be standalone: true.",
      "Import PrimeNG modules in imports array: ButtonModule, InputTextModule, TableModule, CardModule, etc.",
      "NEVER import Angular Material from @angular/material.",
      "NEVER use Bootstrap classes (btn, col-md-*, container, row).",
      "Import primeicons CSS: the icons use class=\"pi pi-pencil\" style.",
      "PrimeNG 17+ uses standalone component imports."
    ]
  }
}
